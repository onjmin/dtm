{
	"author": "onjmin",
	"license": "MIT",
	"name": "@onjmin/dtm",
	"version": "0.1.56",
	"description": "MMLを中間言語に用いた、モバイルファーストなDAW / ピアノロール打ち込みコンポーネント",
	"homepage": "https://onjmin.github.io/dtm",
	"repository": {
		"type": "git",
		"url": "https://github.com/onjmin/dtm.git"
	},
	"bugs": {
		"url": "https://github.com/onjmin/dtm/issues"
	},
	"main": "dist/index.js",
	"module": "dist/index.mjs",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.js"
		}
	},
	"sideEffects": false,
	"scripts": {
		"dev": "rimraf dist && tsup && biome format src --write && tsx demo/server.ts",
		"build": "rimraf dist && tsup && biome format src --write",
		"check": "biome check src --write",
		"prepublishOnly": "pnpm run build",
		"patch": "pnpm version patch",
		"publish-dangerous-dont-use-this-command": "pnpm publish --access public"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"piano-roll",
		"mml",
		"music",
		"sequencer",
		"editor",
		"daw",
		"mobile-first",
		"canvas",
		"web-audio"
	],
	"packageManager": "pnpm@10.11.0",
	"volta": {
		"node": "22.15.1",
		"pnpm": "10.11.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.3",
		"@discord/embedded-app-sdk": "2.5.0",
		"@hono/node-server": "1.19.5",
		"esbuild": "0.28.1",
		"hono": "4.10.1",
		"rimraf": "6.0.1",
		"tsup": "8.5.1",
		"tsx": "4.20.6",
		"typedoc": "0.28.19",
		"typescript": "5.8.3"
	},
	"dependencies": {
		"@onjmin/chord-parser": "1.0.2",
		"@onjmin/dtm": "0.1.14",
		"@onjmin/koe": "1.0.4",
		"midi-json-parser": "8.1.74"
	}
}
